# ===== 当前方案：DeepSeek + BGE（硅基流动）=====

# DeepSeek — Query Rewrite + LLM 生成
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# 硅基流动 SiliconFlow — BGE Embedding + BGE Reranker
# 获取地址：https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=

# ===== 备用 Keys（可选，切换 provider 时需要）=====

# Anthropic — Claude Haiku/Sonnet
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — GPT / text-embedding-3-large
OPENAI_API_KEY=sk-...

# Cohere — Rerank API
COHERE_API_KEY=...

# ===== 使用方法 =====
# cp .env.example .env
# 填入 DEEPSEEK_API_KEY 和 SILICONFLOW_API_KEY 即可启动
